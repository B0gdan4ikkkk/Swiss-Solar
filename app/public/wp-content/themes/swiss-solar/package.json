{
  "name": "swiss-solar-theme",
  "version": "1.0.0",
  "description": "WordPress тема Swiss Solar с Tailwind CSS",
  "scripts": {
    "dev": "npm run build:css -- --watch",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/style.css -o ./dist/style.css --minify"
  },
  "keywords": [
    "wordpress",
    "theme",
    "tailwindcss"
  ],
  "author": "Swiss Solar Team",
  "license": "GPL-2.0",
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}

